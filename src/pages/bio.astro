---
import Layout from "../layouts/Layout.astro";
import { bioButtons } from "@content/bio-buttons";

const title = "Bio | Alfian Nahar";
const description =
  "Quick links and social profiles for Alfian Nahar, an AI developer and designer.";

const socialLinks = [
  { label: "GitHub", href: "https://github.com/alfianahar", icon: "github" },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/alfianahar/",
    icon: "linkedin",
  },
  {
    label: "Instagram",
    href: "https://www.instagram.com/alfianahar/",
    icon: "instagram",
  },
];
---

<Layout title={title} description={description} hideHeader>
  <div data-theme="dark" class="flex min-h-dvh items-center justify-center bg-[var(--background)]">
    <div
      class="relative flex h-dvh w-full flex-col overflow-hidden border-[length:var(--border-bold)] border-[var(--brutal-ink)] bg-[var(--background)] shadow-[var(--shadow-hard)] md:h-[85dvh] md:w-[32rem] md:rounded-[var(--radius-lg)]"
    >
      <div
        class="pointer-events-none absolute inset-0 z-0 flex items-center justify-center py-12 opacity-10 lg:items-end"
      >
        <img src="/an-logo.svg" alt="" class="w-48 sm:w-64" />
      </div>

      <div class="relative z-10 flex min-h-0 flex-1 flex-col">
        <div class="flex shrink-0 gap-1.5 px-5 pt-5 sm:px-6 sm:pt-6">
          <div class="h-1 flex-1 rounded-full bg-white/20">
            <div class="slide-progress h-full w-0 rounded-full bg-[var(--accent)]"></div>
          </div>
          <div class="h-1 flex-1 rounded-full bg-white/20">
            <div class="slide-progress h-full w-0 rounded-full bg-[var(--accent)]"></div>
          </div>
        </div>

        <div class="bio-slides min-h-0 w-full min-w-0 flex-1" tabindex="0" aria-label="Bio slides">
          <div class="bio-track">
            <section class="bio-slide">
              <div class="flex h-full flex-col items-center px-6 pb-14 pt-12 text-center">
                <div class="relative inline-flex">
                  <div
                    class="grid size-24 place-items-center rounded-full border-[length:var(--border-bold)] border-[var(--brutal-ink)] bg-[var(--cream)] shadow-[var(--shadow-hard-sm)] sm:size-28"
                  >
                    <img
                      src="https://github.com/alfianahar.png"
                      alt="Alfian Nahar"
                      width={112}
                      height={112}
                      class="size-full rounded-full object-cover"
                    />
                  </div>
                </div>

                <h1 class="mt-4 text-xl font-medium text-[var(--text-primary)] sm:text-2xl">
                  Alfian Nahar
                </h1>
                <p class="mt-3 font-light leading-6 tracking-widest text-[var(--text-secondary)]">
                  Full Stack Developer with <br /> Minimal UI/UX Design Skills
                </p>

                <div class="mt-6 flex items-center gap-6">
                  {
                    socialLinks.map((link) => (
                      <a
                        href={link.href}
                        target="_blank"
                        rel="noreferrer"
                        class="transition duration-300 hover:scale-125 hover:ease-out"
                        aria-label={link.label}
                      >
                        <box-icon
                          type="logo"
                          name={link.icon}
                          color="var(--text-primary)"
                          size="sm"
                        />
                      </a>
                    ))
                  }
                </div>

                <div class="mt-8 flex w-full max-w-xs flex-col gap-4">
                  {
                    bioButtons.map((button) => (
                      <a
                        href={button.target}
                        target={button.target.startsWith("http") ? "_blank" : undefined}
                        rel={button.target.startsWith("http") ? "noreferrer" : undefined}
                        class="brutal-press flex h-14 w-full items-center justify-center gap-2 rounded-[var(--radius-md)] border-[length:var(--border-bold)] border-[var(--brutal-ink)] bg-[var(--cream)] px-4 text-center font-semibold text-[var(--brutal-ink)] shadow-[var(--shadow-hard)]"
                      >
                        <box-icon
                          type={button.icon.type || undefined}
                          name={button.icon.name}
                          color="var(--brutal-ink)"
                          size="md"
                        />
                        <span class="flex-grow">{button.title}</span>
                      </a>
                    ))
                  }
                </div>
              </div>
            </section>

            <section class="bio-slide">
              <div class="flex h-full w-full flex-col px-6 pb-14 pt-12">
                <div
                  class="mx-auto flex w-full max-w-[34rem] flex-1 flex-col items-center justify-start gap-8 pt-2 sm:gap-10"
                >
                  <div
                    class="relative w-full rounded-[var(--radius-lg)] border-[length:var(--border-bold)] border-[var(--brutal-ink)] bg-[var(--cream)] px-5 pb-5 pt-8 text-center shadow-[var(--shadow-hard-sm)] sm:px-6"
                  >
                    <h5
                      class="absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/2 bg-[var(--cream)] px-3 py-1 font-mono text-sm text-[var(--brutal-ink)] sm:text-base"
                    >
                      Hello, i am
                    </h5>
                    <h3
                      class="text-3xl font-semibold leading-none text-[var(--brutal-ink)] sm:text-5xl"
                    >
                      Alfian Nahar
                    </h3>
                    <p
                      class="mx-auto mt-4 max-w-xl font-light leading-7 tracking-[0.18em] text-[var(--brutal-ink)] opacity-70 sm:text-lg"
                    >
                      Energetic, motivated and eager to learn new skillset! Professional full-stack
                      developer with a motivation to build something awesome
                    </p>
                  </div>

                  <div
                    class="pointer-events-none relative w-full flex-1 min-h-[26rem] overflow-hidden rounded-[var(--radius-lg)] border-[length:var(--border-bold)] border-[var(--brutal-ink)] shadow-[var(--shadow-hard-sm)] sm:min-h-[30rem]"
                  >
                    <img
                      src="/me-bg.png"
                      alt="Alfian Nahar"
                      width={500}
                      height={500}
                      loading="lazy"
                      draggable="false"
                      class="absolute inset-x-0 bottom-0 h-full w-full select-none object-cover object-[center_10%] grayscale"
                    />
                  </div>
                </div>
              </div>
            </section>
          </div>
        </div>
      </div>

      <div
        class="absolute bottom-4 left-0 z-50 flex h-6 w-full items-center justify-center gap-1 font-light text-[var(--text-muted)]"
      >
        Made by
        <img src="/an-logo-blue.svg" alt="" class="h-4 w-auto" />
      </div>
    </div>
  </div>

  <script is:inline src="https://unpkg.com/boxicons@2.1.1/dist/boxicons.js"></script>
</Layout>

<style>
  .bio-slides {
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    cursor: grab;
  }

  .bio-slides.is-dragging {
    cursor: grabbing;
    scroll-snap-type: none;
  }

  .bio-slides::-webkit-scrollbar {
    display: none;
  }

  .bio-track {
    display: flex;
    height: 100%;
  }

  .bio-slide {
    flex: 0 0 100%;
    height: 100%;
    scroll-snap-align: start;
  }
</style>

<script>
  const slides = document.querySelector<HTMLElement>(".bio-slides");
  if (slides) {
    const progressBars =
      slides.parentElement?.querySelectorAll<HTMLElement>(".slide-progress") ?? [];

    const setProgress = () => {
      const maxScroll = slides.scrollWidth - slides.clientWidth;
      const p = maxScroll > 0 ? slides.scrollLeft / maxScroll : 0;
      const n = progressBars.length;
      progressBars.forEach((bar, i) => {
        const fill = Math.max(0, Math.min(1, 1 - Math.abs(p * (n - 1) - i)));
        bar.style.width = fill * 100 + "%";
      });
    };

    slides.addEventListener("scroll", setProgress, { passive: true });
    window.addEventListener("resize", setProgress);

    let dragPointerId: number | null = null;
    let dragStartX = 0;
    let dragStartLeft = 0;
    let didDrag = false;
    const interactiveSelector = "a, button, input, textarea, select, label";

    const snapToNearestSlide = () => {
      slides.scrollTo({
        left: Math.round(slides.scrollLeft / slides.clientWidth) * slides.clientWidth,
        behavior: "smooth",
      });
    };

    slides.addEventListener("pointerdown", (event) => {
      if (event.button !== 0) return;
      if (event.target instanceof Element && event.target.closest(interactiveSelector)) {
        didDrag = false;
        return;
      }

      dragPointerId = event.pointerId;
      dragStartX = event.clientX;
      dragStartLeft = slides.scrollLeft;
      didDrag = false;
      slides.setPointerCapture(event.pointerId);
      slides.classList.add("is-dragging");
    });

    slides.addEventListener("pointermove", (event) => {
      if (event.pointerId !== dragPointerId) return;

      const delta = dragStartX - event.clientX;
      didDrag = didDrag || Math.abs(delta) > 4;
      if (!didDrag) return;

      event.preventDefault();
      slides.scrollLeft = dragStartLeft + delta;
    });

    slides.addEventListener("pointerup", (event) => {
      if (event.pointerId !== dragPointerId) return;

      dragPointerId = null;
      slides.releasePointerCapture(event.pointerId);
      slides.classList.remove("is-dragging");
      snapToNearestSlide();
    });

    slides.addEventListener("click", (event) => {
      if (!didDrag) return;

      event.preventDefault();
      didDrag = false;
    });

    slides.addEventListener("keydown", (event) => {
      if (event.key !== "ArrowLeft" && event.key !== "ArrowRight") return;

      event.preventDefault();
      slides.scrollBy({
        left: event.key === "ArrowRight" ? slides.clientWidth : -slides.clientWidth,
        behavior: "smooth",
      });
    });

    setProgress();
  }
</script>
