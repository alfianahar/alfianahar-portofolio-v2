# OpenRouter API Configuration
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# Site metadata for OpenRouter leaderboard (optional)
OPENROUTER_SITE_URL=https://alfianahar.com
OPENROUTER_SITE_NAME=Alfian's Portfolio

# Model tuning (optional)
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_MAX_TOKENS=500
# Set to "true" to enable reasoning tokens (for models that support it)
OPENROUTER_REASONING=false
