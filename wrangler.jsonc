{
  "name": "alfianahar-portofolio-v2",
  "compatibility_date": "2026-06-23",
  "main": "./dist/_worker.js/index.js",
  "assets": {
    "directory": "./dist"
  },
  "vars": {
    "LLM_BASE_URL": "https://api.deepseek.com/v1",
    "LLM_MODEL": "deepseek-v4-flash",
    "LLM_TEMPERATURE": "0.5",
    "LLM_MAX_TOKENS": "10000"
  },
  "kv_namespaces": [
    {
      "binding": "SESSION"
    }
  ]
}
